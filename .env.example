# ─── API 키 설정 ───────────────────────────────────
# 이 파일을 .env로 복사 후 실제 키를 입력하세요
# cp .env.example .env

# Vworld (https://www.vworld.kr → 인증키 발급)
VWORLD_API_KEY=

# 공공데이터포털 (https://www.data.go.kr → 마이페이지 → 인증키)
DATA_GO_KR_API_KEY=

# 카카오 개발자 (https://developers.kakao.com → 앱 → REST API 키)
KAKAO_REST_API_KEY=

# Google Cloud Vision (https://console.cloud.google.com → API 및 서비스)
GOOGLE_VISION_API_KEY=
